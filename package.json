{
  "name": "chromedia-talent-intelligence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n backend,frontend \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "vite --config frontend/vite.config.ts",
    "dev:backend": "node --import tsx --watch backend/src/server.ts",
    "start:backend": "node --import tsx backend/src/server.ts",
    "typecheck": "tsc -p frontend/tsconfig.json --pretty false && tsc -p backend/tsconfig.json --pretty false",
    "build": "npm run typecheck && vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "db:generate": "prisma generate --config backend/prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config backend/prisma.config.ts",
    "db:studio": "prisma studio --config backend/prisma.config.ts --port 5555 --browser none",
    "db:import": "node --import tsx scripts/import-json-to-postgres.ts",
    "db:import:candidates": "node --import tsx scripts/import-candidates-to-postgres.ts",
    "db:import:skills": "node --import tsx scripts/import-skills-to-postgres.ts",
    "db:verify": "node --import tsx scripts/verify-import-counts.ts",
    "db:restore-dummy": "node --import tsx scripts/restore-dummy-json.ts",
    "db:generate-rich-dummy": "node --import tsx scripts/generate-rich-dummy-data.ts",
    "db:apply-skills-updated": "node --import tsx scripts/apply-updated-skills.ts",
    "db:apply-candidates-updated": "node --import tsx scripts/apply-updated-candidates.ts",
    "db:reseed-rich": "npm run db:generate-rich-dummy && npm run db:import -- --wipe && npm run db:verify",
    "migrate:skill-selections": "node scripts/migrate-skill-selection-capability-ids.mjs",
    "test:api": "node scripts/test-api-integration.mjs",
    "test:domain": "node scripts/test-candidate-profile-domain.mjs",
    "test": "npm run test:api",
    "test:share-links": "node scripts/test-share-link-lifecycle.mjs",
    "test:rbac-smoke": "node scripts/smoke-user-rbac.mjs",
    "test:all": "npm run test:domain && npm run test:api && npm run test:share-links"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
