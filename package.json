{
  "name": "chromedia-talent-intelligence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "typecheck": "tsc -p frontend/tsconfig.json --pretty false && tsc -p backend/tsconfig.json --pretty false",
    "build": "npm run typecheck && vite build --config frontend/vite.config.ts",
    "preview": "vite preview --config frontend/vite.config.ts",
    "db:generate": "prisma generate --config backend/prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config backend/prisma.config.ts",
    "db:studio": "prisma studio --config backend/prisma.config.ts --port 5555 --browser none",
    "db:import": "node --import tsx scripts/import-json-to-postgres.ts",
    "db:verify": "node --import tsx scripts/verify-import-counts.ts",
    "migrate:skill-selections": "node scripts/migrate-skill-selection-capability-ids.mjs",
    "test:api": "node scripts/test-api-integration.mjs",
    "test:domain": "node scripts/test-candidate-profile-domain.mjs",
    "test": "npm run test:api",
    "test:share-links": "node scripts/test-share-link-lifecycle.mjs",
    "test:all": "npm run test:domain && npm run test:api && npm run test:share-links"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
